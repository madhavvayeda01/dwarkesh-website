generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  fullName    String
  companyName String?
  email       String?
  phone       String
  message     String?
  createdAt   DateTime @default(now())
}

model Consultant {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  active    Boolean  @default(true)
  pageAccess Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedAuditSchedules      AuditSchedule[]     @relation("AuditScheduleOwner")
  createdAuditSchedules    AuditSchedule[]     @relation("AuditScheduleCreator")
  uploadedAuditAttachments AuditAttachment[]   @relation("AuditAttachmentUploader")
}

model Client {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String

  logoUrl       String?
  address       String?
  contactNumber String?

  createdAt     DateTime @default(now())

  employees     Employee[]
  templates     DocumentTemplate[]
  moduleControl ModuleControl?
  shiftConfig   ClientShiftConfig?
  holidays      ClientHoliday[]
  payrollRecords PayrollRecord[]
  chatMessages  ClientChatMessage[]
  complianceDocuments ComplianceLegalDocument[]
  complianceScheduleTemplates ComplianceScheduleTemplate[]
  complianceScheduleEvents ComplianceScheduleEvent[]
  complianceNotifications ComplianceNotification[]
  auditSchedules AuditSchedule[]
  chatThreadReadStates ChatThreadReadState[]
}

model Employee {
  id       String @id @default(cuid())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // ====== EMPLOYEE MASTER FULL FIELDS ======

  empNo     String?
  fileNo    String?
  pfNo      String?
  uanNo     String?
  esicNo    String?

  firstName          String?
  surName            String?
  fatherSpouseName   String?
  fullName           String?
  employmentStatus   EmployeeStatus @default(ACTIVE)
  employeeFileStatus EmployeeFileStatus @default(PENDING)
  shiftCategory      EmployeeShiftCategory @default(WORKER)

  designation  String?
  currentDept  String?
  salaryWage   String?

  dob           String?
  doj           String?
  dor           String?
  reasonForExit String?

  panNo             String?
  aadharNo          String?
  elcIdNo           String?
  drivingLicenceNo  String?

  bankAcNo   String?
  ifscCode   String?
  bankName   String?

  mobileNumber        String?
  gender              String?
  religion            String?
  nationality         String?
  typeOfEmployment    String?
  maritalStatus       String?
  educationQualification String?
  experienceInRelevantField String?

  presentAddress   String?
  permanentAddress String?
  village          String?
  thana            String?
  subDivision      String?
  postOffice       String?
  district         String?
  state            String?
  pinCode          String?
  temporaryAddress String?

  nominee1Name       String?
  nominee1Relation   String?
  nominee1BirthDate  String?
  nominee1Age        String?
  nominee1Proportion String?

  nominee2Name       String?
  nominee2Relation   String?
  nominee2BirthDate  String?
  nominee2Age        String?
  nominee2Proportion String?

  createdAt DateTime @default(now())
  attendances Attendance[]
  payrollRecords PayrollRecord[]

  @@index([clientId])
  @@index([clientId, employmentStatus])
  @@index([clientId, shiftCategory])
}

model Attendance {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  status       String   @default("A")
  generationSeed String?
  inTime       String?
  outTime      String?
  breakMinutes Int
  workHours    Float
  otHours      Float
  month        Int
  year         Int
  createdAt    DateTime @default(now())

  @@unique([employeeId, date])
  @@index([month, year])
  @@index([employeeId, month, year])
}

model DocumentGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  templates DocumentTemplate[]
}

model DocumentTemplate {
  id        String   @id @default(cuid())

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  groupId   String
  group     DocumentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  title     String
  fileUrl   String
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([groupId])
}

model AuditParameterOption {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditDocumentOption {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditFloorOption {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProgramAudit {
  id                String   @id @default(cuid())
  name              String
  parameterOptionIds String[]
  documentOptionIds  String[]
  floorOptionIds     String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  auditSchedules    AuditSchedule[]

  @@index([name])
}

model AuditSchedule {
  id                    String              @id @default(cuid())
  clientId              String
  client                Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  programAuditId        String?
  programAudit          ProgramAudit?       @relation(fields: [programAuditId], references: [id], onDelete: SetNull)
  title                 String
  description           String?
  status                AuditScheduleStatus @default(DRAFT)
  priority              AuditPriority       @default(MEDIUM)
  mode                  AuditMode           @default(ONSITE)
  location              String?
  scheduledStartAt      DateTime
  scheduledEndAt        DateTime?
  ownerConsultantId     String?
  ownerConsultant       Consultant?         @relation("AuditScheduleOwner", fields: [ownerConsultantId], references: [id], onDelete: SetNull)
  createdByAdminType    AuditActorType
  createdByConsultantId String?
  createdByConsultant   Consultant?         @relation("AuditScheduleCreator", fields: [createdByConsultantId], references: [id], onDelete: SetNull)
  createdByNameSnapshot String?
  followUpAt            DateTime?
  internalNotes         String?
  outcomeSummary        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  visits          AuditVisit[]
  checklistItems  AuditChecklistItem[]
  attachments     AuditAttachment[]
  reminderNotices AuditReminderNotice[]

  @@index([clientId, scheduledStartAt])
  @@index([status, scheduledStartAt])
  @@index([ownerConsultantId, scheduledStartAt])
  @@index([programAuditId])
}

model AuditVisit {
  id             String          @id @default(cuid())
  auditScheduleId String
  auditSchedule  AuditSchedule   @relation(fields: [auditScheduleId], references: [id], onDelete: Cascade)
  title          String
  purpose        String?
  plannedStartAt DateTime
  plannedEndAt   DateTime?
  location       String?
  contactPerson  String?
  status         AuditVisitStatus @default(PLANNED)
  notes          String?
  outcome        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  attachments     AuditAttachment[]
  checklistItems  AuditChecklistItem[]
  reminderNotices AuditReminderNotice[]

  @@index([auditScheduleId, plannedStartAt])
  @@index([status, plannedStartAt])
}

model AuditChecklistItem {
  id             String               @id @default(cuid())
  auditScheduleId String
  auditSchedule  AuditSchedule        @relation(fields: [auditScheduleId], references: [id], onDelete: Cascade)
  visitId        String?
  visit          AuditVisit?          @relation(fields: [visitId], references: [id], onDelete: SetNull)
  source         AuditChecklistSource
  label          String
  details        String?
  sortOrder      Int                  @default(0)
  completed      Boolean              @default(false)
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([auditScheduleId, sortOrder])
  @@index([visitId])
  @@index([completed])
}

model AuditAttachment {
  id                    String          @id @default(cuid())
  auditScheduleId       String
  auditSchedule         AuditSchedule   @relation(fields: [auditScheduleId], references: [id], onDelete: Cascade)
  visitId               String?
  visit                 AuditVisit?     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  fileName              String
  fileUrl               String
  filePath              String
  uploadedByAdminType   AuditActorType
  uploadedByConsultantId String?
  uploadedByConsultant  Consultant?     @relation("AuditAttachmentUploader", fields: [uploadedByConsultantId], references: [id], onDelete: SetNull)
  createdAt             DateTime        @default(now())

  @@index([auditScheduleId, createdAt])
  @@index([visitId, createdAt])
}

model AuditReminderNotice {
  id             String                    @id @default(cuid())
  auditScheduleId String
  auditSchedule  AuditSchedule             @relation(fields: [auditScheduleId], references: [id], onDelete: Cascade)
  visitId        String?
  visit          AuditVisit?               @relation(fields: [visitId], references: [id], onDelete: Cascade)
  kind           AuditReminderKind
  title          String
  message        String
  notifyAt       DateTime
  emailTo        String[]                  @default([])
  emailStatus    AuditReminderEmailStatus  @default(PENDING)
  emailError     String?
  emailSentAt    DateTime?
  createdAt      DateTime                  @default(now())

  @@index([auditScheduleId, notifyAt])
  @@index([visitId, notifyAt])
  @@index([emailStatus, notifyAt])
}

model ModuleControl {
  id                    String   @id @default(cuid())
  clientId              String   @unique
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employeesEnabled      Boolean  @default(true)
  payrollEnabled        Boolean  @default(true)
  inOutEnabled          Boolean  @default(true)
  complianceEnabled     Boolean  @default(true)
  trainingEnabled       Boolean  @default(true)
  committeesEnabled     Boolean  @default(true)
  documentsEnabled      Boolean  @default(true)
  auditEnabled          Boolean  @default(true)
  chatEnabled           Boolean  @default(true)
  notificationsEnabled  Boolean  @default(true)
  pageAccess            Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum WeekendType {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
  ROTATIONAL
}

model ClientShiftConfig {
  id                String      @id @default(cuid())
  clientId          String      @unique
  client            Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  generalShiftEnabled Boolean   @default(true)
  generalShiftStart DateTime    @db.Time(0)
  generalShiftEnd   DateTime    @db.Time(0)
  shiftAEnabled     Boolean     @default(true)
  shiftAStart       DateTime    @db.Time(0)
  shiftAEnd         DateTime    @db.Time(0)
  shiftBEnabled     Boolean     @default(true)
  shiftBStart       DateTime    @db.Time(0)
  shiftBEnd         DateTime    @db.Time(0)
  shiftCEnabled     Boolean     @default(true)
  shiftCStart       DateTime    @db.Time(0)
  shiftCEnd         DateTime    @db.Time(0)
  weekendType       WeekendType
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model ClientHoliday {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date      DateTime
  name      String
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, date])
  @@index([year])
  @@index([clientId, year])
}

model PayrollRecord {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  month         Int
  year          Int
  employeeCode  String
  employeeName  String?
  payDays       Float
  otHoursTarget Float   @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([clientId, year, month, employeeCode])
  @@index([clientId, year, month])
  @@index([clientId, year, month, employeeId])
}

model ClientChatMessage {
  id        String     @id @default(cuid())
  clientId  String
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sender    ChatSender
  text      String
  createdAt DateTime   @default(now())

  @@index([clientId, createdAt])
}

model ChatThreadReadState {
  id            String                    @id @default(cuid())
  recipientType NotificationRecipientType
  recipientId   String
  clientId      String
  client        Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lastReadAt    DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@unique([recipientType, recipientId, clientId])
  @@index([recipientType, recipientId, lastReadAt])
  @@index([clientId, lastReadAt])
}

model ComplianceLegalDocument {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  documentStatus ComplianceDocumentStatus @default(ACTIVE)
  issueDate  DateTime?
  expiryDate DateTime?
  remarks    String?
  fileUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  notifications ComplianceNotification[]

  @@index([clientId, expiryDate])
}

model ComplianceScheduleTemplate {
  id        String                     @id @default(cuid())
  clientId  String
  client    Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category  ComplianceScheduleCategory
  title     String
  fileUrl   String
  createdAt DateTime                   @default(now())

  scheduleEvents ComplianceScheduleEvent[]

  @@index([clientId, category])
}

model ComplianceScheduleEvent {
  id               String                     @id @default(cuid())
  clientId         String
  client           Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category         ComplianceScheduleCategory
  title            String
  scheduledFor     DateTime
  templateId       String?
  template         ComplianceScheduleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  generatedFileUrl String?
  generatedFilePath String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([clientId, category, scheduledFor])
}

model ComplianceNotification {
  id         String                        @id @default(cuid())
  clientId   String
  client     Client                        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documentId String
  document   ComplianceLegalDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  audience   ComplianceNotificationAudience
  kind       ComplianceNotificationKind
  notifyAt   DateTime
  title      String
  message    String
  createdAt  DateTime                      @default(now())

  @@unique([documentId, audience, kind])
  @@index([clientId, audience, createdAt])
}

model NotificationReadState {
  id            String                    @id @default(cuid())
  recipientType NotificationRecipientType
  recipientId   String
  sourceType    NotificationSourceType
  sourceId      String
  readAt        DateTime                  @default(now())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@unique([recipientType, recipientId, sourceType, sourceId])
  @@index([recipientType, recipientId, readAt])
  @@index([sourceType, sourceId])
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum EmployeeFileStatus {
  PENDING
  CREATED
}

enum EmployeeShiftCategory {
  STAFF
  WORKER
}

enum ChatSender {
  client
  admin
}

enum ComplianceScheduleCategory {
  TRAINING
  COMMITTEE
}

enum ComplianceNotificationAudience {
  ADMIN
  CLIENT
}

enum ComplianceNotificationKind {
  EXPIRY_30_DAYS
  EXPIRY_7_DAYS
  EXPIRY_1_DAY
  EXPIRED
}

enum ComplianceDocumentStatus {
  ACTIVE
  NOT_APPLICABLE
  NOT_AVAILABLE
}

enum NotificationRecipientType {
  ADMIN
  CLIENT
}

enum NotificationSourceType {
  COMPLIANCE
  AUDIT
}

enum AuditActorType {
  ENV_ADMIN
  CONSULTANT
}

enum AuditScheduleStatus {
  DRAFT
  SCHEDULED
  VISIT_PLANNED
  IN_PROGRESS
  COMPLETED
  RESCHEDULED
  CANCELLED
  OVERDUE
}

enum AuditVisitStatus {
  PLANNED
  DONE
  MISSED
  RESCHEDULED
  CANCELLED
}

enum AuditPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditMode {
  ONSITE
  REMOTE
  HYBRID
}

enum AuditChecklistSource {
  PARAMETER
  DOCUMENT
  FLOOR
  MANUAL
}

enum AuditReminderKind {
  AUDIT_24H
  AUDIT_2H
  VISIT_24H
  VISIT_2H
  AUDIT_OVERDUE
  VISIT_OVERDUE
}

enum AuditReminderEmailStatus {
  PENDING
  SENT
  SKIPPED
  FAILED
}
